    "@types/node": "20.16.10",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "eslint": "8.57.1",
    "eslint-config-next": "^14.2.35",
    "prisma": "^5.20.0",
    "tsx": "4.20.5",
    "typescript": "5.6.3",
