{
  "name": "promptpilot",
  "version": "1.2.1",
  "description": "Interactive AI lessons with verified step-by-step practice, telemetry-safe progress tracking, and a Chrome extension bridge.",
  "private": true,
  "license": "MIT",
  "homepage": "https://github.com/bishaldan/promptpilot",
  "repository": {
    "type": "git",
